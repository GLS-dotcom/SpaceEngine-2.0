          cat > Engine/Logging/src/Logger.cpp <<'CPP_LOG'
#include "Cosmos/Logging/Logger.h"
#include <iostream>
#include <filesystem>
#include <ctime>

using namespace Cosmos::Logging;

static std::string Timestamp() {
    std::time_t t = std::time(nullptr);
    char buf[64];
    std::strftime(buf, sizeof(buf), "%Y-%m-%d %H:%M:%S", std::localtime(&t));
    return std::string(buf);
}

Logger::Logger() {
    try {
        std::filesystem::create_directories("logs");
        m_File.open("logs/engine.log", std::ios::app);
    } catch(...) {}
}

Logger::~Logger() {
    if (m_File.is_open()) m_File.close();
}

void Logger::Info(const std::string& msg) {
    std::lock_guard<std::mutex> lk(m_Mutex);
    std::string line = Timestamp() + " [INFO] " + msg;
    std::cout << line << std::endl;
    if (m_File.is_open()) m_File << line << std::endl;
}

void Logger::Info(const char* fmt, int value) {
    char buf[64];
    std::snprintf(buf, sizeof(buf), fmt, value);
    Info(std::string(buf));
}

void Logger::Error(const std::string& msg) {
    std::lock_guard<std::mutex> lk(m_Mutex);
    std::string line = Timestamp() + " [ERROR] " + msg;
    std::cerr << line << std::endl;
    if (m_File.is_open()) m_File << line << std::endl;
}

void Logger::Debug(const std::string& msg) {
    std::lock_guard<std::mutex> lk(m_Mutex);
    std::string line = Timestamp() + " [DEBUG] " + msg;
    std::cout << line << std::endl;
    if (m_File.is_open()) m_File << line << std::endl;
}
