name: Apply Phase0 Skeleton - full

permissions:
  contents: write
  pull-requests: write

on:
  workflow_dispatch:

jobs:
  apply:
    runs-on: ubuntu-latest
    steps:
      - name: Check out repository
        uses: actions/checkout@v4
        with:
          fetch-depth: 0
          persist-credentials: true

      - name: Install dependencies (jq)
        run: |
          sudo apt-get update
          sudo apt-get install -y jq

      - name: Create/checkout branch
        run: |
          BRANCH="feature/phase0-init"
          if git ls-remote --exit-code --heads origin "$BRANCH"; then
            git fetch origin "$BRANCH":"$BRANCH"
            git checkout "$BRANCH"
          else
            git checkout -b "$BRANCH"
          fi

      - name: Write project files (Phase 0 skeleton)
        run: |
          set -e
          mkdir -p src/Launcher \
                   Engine/Core/include/Cosmos/Core \
                   Engine/Core/src \
                   Engine/Logging/include/Cosmos/Logging \
                   Engine/Logging/src \
                   Engine/Config/include/Cosmos/Config \
                   Engine/Config/src \
                   .github/workflows

