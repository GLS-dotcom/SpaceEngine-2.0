          cat > Engine/Core/src/Engine.cpp <<'CPP_ENGINE'
#include "Cosmos/Core/Engine.h"

#include <chrono>
#include <thread>
#include <filesystem>

#include "Cosmos/Core/Application.h"
#include "Cosmos/Core/Timer.h"
#include "Cosmos/Logging/Logger.h"
#include "Cosmos/Config/ConfigManager.h"

namespace Cosmos {

Engine* Engine::s_Instance = nullptr;

Engine::Engine(int argc, char* argv[])
    : m_Argc(argc)
    , m_Application(std::make_unique<Application>())
    , m_Timer(std::make_unique<Timer>())
    , m_Logger(std::make_unique<Logger>())
    , m_ConfigManager(std::make_unique<ConfigManager>())
{
    s_Instance = this;
    for (int i = 0; i < argc; ++i) m_Argv.emplace_back(argv[i]);
}

Engine::~Engine() {
    if (m_Initialized) Shutdown();
    s_Instance = nullptr;
}

bool Engine::Initialize() {
    if (m_Initialized) return true;

    try {
        std::filesystem::create_directories("logs");
    } catch(...) {}

    m_Logger->Info("SpaceEngine-2.0 initializing...");

    if (!m_ConfigManager->Initialize("config/engine.json")) {
        m_Logger->Error("ConfigManager initialization failed (continuing with defaults)");
    }

    m_Timer->Start();

    if (!m_Application->Initialize()) {
        m_Logger->Error("Application initialization failed");
        return false;
    }

    m_Initialized = true;
    m_Logger->Info("Initialization complete");
    return true;
}

int Engine::Run() {
    if (!m_Initialized) {
        m_Logger->Error("Engine not initialized");
        return 1;
    }

    m_Running = true;
    m_Logger->Info("Entering main loop");

    while (m_Running) {
        UpdateTiming();
        m_FrameCount++;

        ProcessEvents();
        Update(m_DeltaTime);
        Render();

        if (m_Application->ShouldClose()) m_Running = false;

        m_FPSTimer += m_DeltaTime;
        if (m_FPSTimer >= 1.0f) {
            m_FPS = m_FrameCount;
            m_FrameCount = 0;
            m_FPSTimer = 0.0f;
            m_Logger->Info("FPS: %d", m_FPS);
        }

        std::this_thread::sleep_for(std::chrono::milliseconds(1));
    }

    m_Logger->Info("Main loop exited");
    return 0;
}

void Engine::Shutdown() {
    if (!m_Initialized) return;

    m_Logger->Info("Shutting down...");
    m_Application->Shutdown();
    m_Initialized = false;
}

void Engine::UpdateTiming() {
    m_Timer->Tick();
    m_DeltaTime = m_Timer->GetDeltaTime();
    m_TotalTime = m_Timer->GetTotalTime();
}

void Engine::ProcessEvents() {
    m_Application->ProcessEvents();
}

void Engine::Update(float deltaTime) {
    m_Application->Update(deltaTime);
}

void Engine::Render() {
    m_Application->Render();
}

} // namespace Cosmos
CPP_ENGINE

