    std::unique_ptr<ConfigManager> m_ConfigManager;

    bool m_Initialized{false};
    bool m_Running{false};
    float m_DeltaTime{0.0f};
    float m_TotalTime{0.0f};
    uint32_t m_FrameCount{0};
    uint32_t m_FPS{0};
